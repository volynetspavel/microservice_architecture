API_GATEWAY_PORT=8080
RESOURCE_SERVICE_PORT=8081
SONG_SERVICE_PORT=8082
RESOURCE_PROCESSOR_PORT=8084
EUREKA_SERVER_PORT=8761
CONFIG_SERVER_PORT=8888

CONFIG_SERVER_URL=http://config-server:8888
CONFIG_REPO_URI=
# Controls how services register their address in Eureka when running in Docker:
#   true  = register with container IP  → use when ALL app services run in Docker
#   false = register with hostname (localhost) → use when gateway or other services run locally
EUREKA_INSTANCE_PREFER_IP_ADDRESS=true

RESOURCE_DATABASE_NAME=resource-db
RESOURCE_DATASOURCE_URL=jdbc:postgresql://resource-db:5432/resource-db
RESOURCE_DATASOURCE_USERNAME=postgres
RESOURCE_DATASOURCE_PASSWORD=postgres

SONG_DATABASE_NAME=song-db
SONG_DATASOURCE_URL=jdbc:postgresql://song-db:5432/song-db
SONG_DATASOURCE_USERNAME=postgres
SONG_DATASOURCE_PASSWORD=postgres

EUREKA_SERVER_URL=http://eureka-server:8761/eureka/

LOCALSTACK_SERVER_URL=http://localstack:4566
LOCALSTACK_AUTH_TOKEN=
LOCALSTACK_ACCESS_KEY=test
LOCALSTACK_SECRET_KEY=test
LOCALSTACK_S3_BUCKET_NAME=microservices

RABBITMQ_SERVER_URL=rabbitmq:5672
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=welcome